# =============================================================================
# open-rag — environment configuration
# Copy this file to .env and fill in the required values.
# =============================================================================

APP_NAME=open-rag
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database
# SQLite is the simplest option for local development.
# For PostgreSQL, change DB_CONNECTION to pgsql and fill in the rest.
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=open_rag
# DB_USERNAME=postgres
# DB_PASSWORD=

# -----------------------------------------------------------------------------
# Session & Queue
# Use database driver for both — no Redis required.
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# -----------------------------------------------------------------------------
# File Storage
# Files are stored locally and deleted after ingestion (metadata kept in DB).
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# OpenAI — used for text-embedding-3-small embeddings
# Get your key at: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Sarvam AI — sarvam-105b is used as the chat LLM
# Get your key at: https://api.sarvam.ai
# -----------------------------------------------------------------------------
SARVAM_API_KEY=your_sarvam_api_key

# -----------------------------------------------------------------------------
# Pinecone — vector database for storing and querying embeddings
# Steps:
#   1. Create a free account at https://pinecone.io
#   2. Create an index with dimension=1536 (text-embedding-3-small output size)
#   3. Copy the index host URL and API key below
# -----------------------------------------------------------------------------
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_HOST=https://your-index-xxxxxxx.svc.pinecone.io
PINECONE_INDEX=open-rag
